class A{
    void show(){
        System.out.println("A in show");
    }
}
class B extends A{
    void show(){
        System.out.println("B in show");
    }
}
class C extends A{
    void show(){
        System.out.println("C in show");
    }
}
public class DynamicDispatch {
    public static void main(String[] args){
        A obj=new A();
        obj.show();

        obj=new B();
        obj.show();

        obj=new C();
        obj.show();
    }
}
